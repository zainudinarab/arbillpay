# ==============================================================================
# KONFIGURASI ENVIRONMENT ARBILLPAY (SAAS BILLING HOTSPOT & POS)
# ==============================================================================
# Salin file ini menjadi `.env` lalu sesuaikan isinya dengan kredensial Anda.
# ==============================================================================

# 1. PORT SERVER & UTILITY
# Port backend Express API (Default: 3006)
PORT=3006

# URL API Backend untuk diakses Frontend React/Vite
VITE_API_URL=http://localhost:3006

# 2. DATABASE POSTGRESQL SERVER
# Masukkan detail koneksi database PostgreSQL milik Anda/VPS
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD='your_postgres_password_here'
DB_NAME=arbill_db

# 3. KREDENSIAL ARABPAY OAUTH S2S (WAJIB DARI https://arabpay.my.id)
# Dapatkan Client ID & Secret dengan mendaftar di: https://arabpay.my.id/dashboard?tab=credentials
ARABPAY_CLIENT_ID=AP_YOUR_CLIENT_ID_HERE
ARABPAY_CLIENT_SECRET='your_arabpay_client_secret_here'

# URL Portal ArabPay E-Wallet (Gateway Resmi)
ARABPAY_PANEL_URL=https://arabpay.my.id

# Redirect URI Otorisasi OAuth (Harus sama persis dengan yang didaftarkan di ArabPay Panel)
ARABPAY_REDIRECT_URI=http://localhost:3005/#/oauth/callback

# 4. HAK AKSES OWNER SUPER ADMIN
# Salin ID Pengguna ArabPay Anda dari menu profil ArabPay (atau tombol Salin ID di Arbill)
# Pengguna yang login via ArabPay SSO dengan ID ini otomatis mendapat role Super Admin / Owner!
ARABPAY_OWNER_USER_ID=YOUR_ARABPAY_USER_ID_HERE
